{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SeedLog",
  "version": "0.1.0",
  "identifier": "com.seedlog.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SeedLog",
        "width": 1280,
        "height": 800,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:seedlog.db"]
    }
  }
}
